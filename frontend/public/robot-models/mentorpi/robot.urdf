<?xml version="1.0" encoding="utf-8"?>
<!-- MentorPi wheeled rover URDF (primitive geometry - no mesh files required) -->
<robot name="mentorpi">

  <material name="chassis_gray">
    <color rgba="0.55 0.55 0.55 1.0"/>
  </material>
  <material name="accent_blue">
    <color rgba="0.18 0.42 0.82 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.12 0.12 0.12 1.0"/>
  </material>
  <material name="sensor_dark">
    <color rgba="0.22 0.22 0.22 1.0"/>
  </material>

  <!-- ===== BASE CHASSIS ===== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.19 0.07"/>
      </geometry>
      <material name="chassis_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.22 0.19 0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.010" iyz="0" izz="0.015"/>
    </inertial>
  </link>

  <!-- Top accent panel -->
  <link name="top_cover">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.17 0.155 0.008"/>
      </geometry>
      <material name="accent_blue"/>
    </visual>
  </link>
  <joint name="top_cover_joint" type="fixed">
    <origin xyz="0 0 0.039" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="top_cover"/>
  </joint>

  <!-- ===== WHEELS (radius 33 mm, width 25 mm) ===== -->
  <!-- Wheels are positioned at ±108 mm laterally, ±76 mm fore-aft,
       and 35 mm below the chassis centre (wheel axis at half chassis height 35mm - 35mm = 0 ground level) -->

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.025"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="front_left_wheel_joint" type="continuous">
    <origin xyz="0.076 0.1075 -0.035" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.025"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="front_right_wheel_joint" type="continuous">
    <origin xyz="0.076 -0.1075 -0.035" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.025"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <origin xyz="-0.076 0.1075 -0.035" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
      <geometry>
        <cylinder radius="0.033" length="0.025"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <origin xyz="-0.076 -0.1075 -0.035" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===== LIDAR TOWER ===== -->
  <link name="lidar_tower">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>
  <joint name="lidar_tower_joint" type="fixed">
    <origin xyz="0.0 0.0 0.055" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_tower"/>
  </joint>

  <!-- LD06 LiDAR disc -->
  <link name="base_laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.022"/>
      </geometry>
      <material name="accent_blue"/>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <origin xyz="0 0 0.031" rpy="0 0 0"/>
    <parent link="lidar_tower"/>
    <child link="base_laser"/>
  </joint>

  <!-- ===== FRONT CAMERA ===== -->
  <link name="front_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.055 0.018"/>
      </geometry>
      <material name="sensor_dark"/>
    </visual>
  </link>
  <joint name="front_camera_joint" type="fixed">
    <origin xyz="0.106 0 0.01" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_camera_link"/>
  </joint>

  <!-- Camera lens dot -->
  <link name="camera_lens">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5707963 0"/>
      <geometry>
        <cylinder radius="0.006" length="0.004"/>
      </geometry>
      <material name="accent_blue"/>
    </visual>
  </link>
  <joint name="camera_lens_joint" type="fixed">
    <origin xyz="0.010 0 0" rpy="0 0 0"/>
    <parent link="front_camera_link"/>
    <child link="camera_lens"/>
  </joint>

</robot>
