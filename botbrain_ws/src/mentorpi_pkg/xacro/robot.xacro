<?xml version="1.0"?>
<!--
  robot.xacro  —  HiWonder MentorPi Pro rover
  Simple box model with 4 wheels.
  Dimensions are approximate for the MentorPi Pro (220 × 190 × 80 mm chassis).
-->
<robot name="mentorpi" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="prefix" default="" />

  <!-- =========================================================== -->
  <!--  Materials                                                    -->
  <!-- =========================================================== -->
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <!-- =========================================================== -->
  <!--  Constants                                                    -->
  <!-- =========================================================== -->
  <xacro:property name="base_length"   value="0.220"/>  <!-- X -->
  <xacro:property name="base_width"    value="0.190"/>  <!-- Y -->
  <xacro:property name="base_height"   value="0.080"/>  <!-- Z -->
  <xacro:property name="base_mass"     value="2.0"/>

  <xacro:property name="wheel_radius"  value="0.033"/>
  <xacro:property name="wheel_width"   value="0.028"/>
  <xacro:property name="wheel_mass"    value="0.15"/>

  <xacro:property name="wheel_x"       value="0.075"/>  <!-- half wheelbase -->
  <xacro:property name="wheel_y"       value="0.110"/>  <!-- half track -->
  <xacro:property name="wheel_z"       value="0.0"/>

  <!-- =========================================================== -->
  <!--  Base link                                                    -->
  <!-- =========================================================== -->
  <link name="$(arg prefix)base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia
        ixx="${base_mass*(base_width*base_width + base_height*base_height)/12.0}"
        ixy="0" ixz="0"
        iyy="${base_mass*(base_length*base_length + base_height*base_height)/12.0}"
        iyz="0"
        izz="${base_mass*(base_length*base_length + base_width*base_width)/12.0}"/>
    </inertial>
  </link>

  <!-- =========================================================== -->
  <!--  Wheel macro                                                  -->
  <!-- =========================================================== -->
  <xacro:macro name="wheel" params="prefix name x y">
    <link name="${prefix}${name}">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)/12.0}"
          ixy="0" ixz="0"
          iyy="${wheel_mass*wheel_radius*wheel_radius/2.0}"
          iyz="0"
          izz="${wheel_mass*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)/12.0}"/>
      </inertial>
    </link>
    <joint name="${prefix}${name}_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}${name}"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="$(arg prefix)" name="front_left_wheel"  x="${wheel_x}"  y="${wheel_y}"/>
  <xacro:wheel prefix="$(arg prefix)" name="front_right_wheel" x="${wheel_x}"  y="${-wheel_y}"/>
  <xacro:wheel prefix="$(arg prefix)" name="rear_left_wheel"   x="${-wheel_x}" y="${wheel_y}"/>
  <xacro:wheel prefix="$(arg prefix)" name="rear_right_wheel"  x="${-wheel_x}" y="${-wheel_y}"/>

  <!-- =========================================================== -->
  <!--  IMU link                                                     -->
  <!-- =========================================================== -->
  <link name="$(arg prefix)imu_link">
    <visual>
      <geometry><box size="0.01 0.01 0.005"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="$(arg prefix)imu_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child  link="$(arg prefix)imu_link"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  Interface link (where BotBrain mounts on top of chassis)    -->
  <!-- =========================================================== -->
  <link name="$(arg prefix)interface_link">
    <visual>
      <geometry><box size="0.05 0.05 0.005"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="$(arg prefix)interface_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child  link="$(arg prefix)interface_link"/>
    <!-- BotBrain sits on top-centre of the chassis -->
    <origin xyz="0.0 0.0 ${base_height + 0.005}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!--  Camera link (front-facing USB camera)                       -->
  <!-- =========================================================== -->
  <link name="$(arg prefix)front_camera_link">
    <visual>
      <geometry><box size="0.02 0.04 0.02"/></geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="$(arg prefix)front_camera_joint" type="fixed">
    <parent link="$(arg prefix)base_link"/>
    <child  link="$(arg prefix)front_camera_link"/>
    <!-- Camera mounts on the front-top edge, pointing forward -->
    <origin xyz="${base_length/2 - 0.01} 0.0 ${base_height + 0.02}" rpy="0 0 0"/>
  </joint>

</robot>
